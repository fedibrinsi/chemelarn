generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PARTICIPANT
}

enum QuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  TRUE_FALSE
  SHORT_ANSWER
  MATCHING
  ORDERING
  LAB_SIMULATION
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  NEEDS_REVIEW
}

enum SenderRole {
  ADMIN
  PARTICIPANT
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  passwordHash        String
  name                String
  role                Role
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  participantProfile  ParticipantProfile?
  createdExams        Exam[]             @relation("ExamCreatedBy")
  generatedCodes      ExamAccessCode[]   @relation("CodeGeneratedBy")
  manualReviews       SubmissionAnswer[] @relation("ManualReviewedBy")
  auditLogs           AuditLog[]
  sentMessages        ChatMessage[]
}

model ParticipantProfile {
  id             String             @id @default(cuid())
  userId         String             @unique
  gradeLevel     String
  schoolName     String?
  studentNumber  String?            @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  examSessions   ExamSession[]
  submissions    Submission[]
  conversation   ChatConversation?
}

model Exam {
  id                   String           @id @default(cuid())
  title                String
  description          String?
  subject              String           @default("Chemistry")
  status               ExamStatus       @default(DRAFT)
  durationMinutes      Int              @default(45)
  availableFrom        DateTime?
  availableUntil       DateTime?
  allowResultReview    Boolean          @default(true)
  allowPastSubmissions Boolean          @default(true)
  instructions         String?
  scoringNotes         String?
  version              Int              @default(1)
  createdById          String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  createdBy            User             @relation("ExamCreatedBy", fields: [createdById], references: [id])
  sections             ExamSection[]
  accessCodes          ExamAccessCode[]
  sessions             ExamSession[]
  learningSummaries    LearningSummary[]
}

model ExamSection {
  id          String     @id @default(cuid())
  examId      String
  title       String
  description String?
  position    Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  exam        Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions   Question[]
}

model Question {
  id              String         @id @default(cuid())
  sectionId       String
  type            QuestionType
  prompt          String
  explanation     String?
  placeholder     String?
  points          Float          @default(1)
  position        Int
  isCaseSensitive Boolean        @default(false)
  config          Json?
  answerKey       Json?
  section         ExamSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  choiceOptions   ChoiceOption[]
  matchingPairs   MatchingPair[]
  answers         SubmissionAnswer[]
}

model ChoiceOption {
  id         String    @id @default(cuid())
  questionId String
  label      String
  value      String
  isCorrect  Boolean   @default(false)
  position   Int
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model MatchingPair {
  id           String    @id @default(cuid())
  questionId   String
  leftLabel    String
  rightLabel   String
  correctMatch String
  position     Int
  question     Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ExamAccessCode {
  id            String        @id @default(cuid())
  examId         String
  code           String        @unique
  maxUses        Int?
  usedCount      Int           @default(0)
  expiresAt      DateTime?
  isActive       Boolean       @default(true)
  generatedById  String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  exam           Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  generatedBy    User          @relation("CodeGeneratedBy", fields: [generatedById], references: [id])
  sessions       ExamSession[]
}

model ExamSession {
  id                String         @id @default(cuid())
  participantId     String
  examId            String
  accessCodeId      String
  status            SessionStatus  @default(NOT_STARTED)
  createdAt         DateTime       @default(now())
  startedAt         DateTime?
  submittedAt       DateTime?
  autoSubmittedAt   DateTime?
  expiresAt         DateTime?
  lastSavedAt       DateTime?
  draftAnswers      Json?
  examSnapshot      Json
  participant       ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  exam              Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  accessCode        ExamAccessCode @relation(fields: [accessCodeId], references: [id], onDelete: Restrict)
  submission        Submission?

  @@index([participantId, status])
}

model Submission {
  id                 String             @id @default(cuid())
  sessionId          String             @unique
  participantId      String
  status             SubmissionStatus   @default(IN_PROGRESS)
  score              Float              @default(0)
  maxScore           Float              @default(0)
  percentage         Float              @default(0)
  autoGradedAt       DateTime?
  gradedAt           DateTime?
  submittedAt        DateTime?
  correctionsVisible Boolean           @default(true)
  answersSnapshot    Json?
  sectionBreakdown   Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  session            ExamSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant        ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  answers            SubmissionAnswer[]
}

model SubmissionAnswer {
  id                 String      @id @default(cuid())
  submissionId       String
  questionId         String
  response           Json?
  autoScore          Float       @default(0)
  finalScore         Float       @default(0)
  maxScore           Float       @default(0)
  isCorrect          Boolean?
  feedback           String?
  requiresManualReview Boolean   @default(false)
  reviewedAt         DateTime?
  reviewedById       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  submission         Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question           Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)
  reviewedBy         User?       @relation("ManualReviewedBy", fields: [reviewedById], references: [id])
}

model LearningSummary {
  id          String    @id @default(cuid())
  examId       String?
  title       String
  content     String
  videoUrl    String?
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  exam        Exam?     @relation(fields: [examId], references: [id], onDelete: SetNull)
}

model ChatConversation {
  id            String          @id @default(cuid())
  participantId String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  participant   ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]
}

model ChatMessage {
  id              String           @id @default(cuid())
  conversationId  String
  senderId        String
  senderRole      SenderRole
  body            String
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User             @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
}
